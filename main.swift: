import Foundation
import PhoneToNIDKit

func main() {
    print("Phone to NID Converter v1.0.0")
    print("================================\n")
    
    let testPhone = "+8801712345678"
    if let result = PhoneToNID.getNIDFromPhone(testPhone) {
        print("✅ Conversion Successful")
        print("Phone: \(result.phoneNumber)")
        print("NID: \(result.nid)")
        print("Status: \(result.status)")
    }
}

main()
