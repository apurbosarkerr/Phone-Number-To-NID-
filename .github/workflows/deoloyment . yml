name: Build and Deploy macOS App

on:
  push:
    tags:
      - 'v*.*.*'
  workflow_dispatch:

jobs:
  build:
    runs-on: macos-latest
    steps:
    - uses: actions/checkout@v4
    - uses: swift-actions/setup-swift@v1
    - run: swift build -c release
    - run: |
        mkdir -p build/PhoneToNID.app/Contents/MacOS
        mkdir -p build/PhoneToNID.app/Contents/Resources
        cp .build/release/PhoneToNID build/PhoneToNID.app/Contents/MacOS/
    - run: hdiutil create -volname "Phone To NID" -srcfolder build/PhoneToNID.app -ov -format UDZO build/PhoneToNID.dmg
    - uses: actions/upload-artifact@v3
      with:
        name: PhoneToNID-macOS
        path: build/PhoneToNID.dmg
